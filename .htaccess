# ----------------------------------------------------------------------
# 1. CONFIGURACIÓN BÁSICA Y RUTAS
# ----------------------------------------------------------------------
RewriteEngine On
RewriteBase /

# Proteger directorios sensibles — ninguno de estos debe ser accesible via HTTP
RewriteRule ^(app|core|vendor|views|database|storage|tests|backup_waf)/ - [F,L]

# Si existe archivo o directorio real, cargarlo directamente
# NOTA: el bloqueo de FilesMatch (sección 3) aplica antes que esta regla en Apache,
#       así que .env y dotfiles nunca llegan aquí aunque existan físicamente.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás al front controller (index.php)
RewriteRule ^ index.php [QSA,L]

# ----------------------------------------------------------------------
# 2. SEGURIDAD DE CABECERAS (Corrige los errores de Nikto)
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    # Evita que el navegador adivine el tipo de archivo (MIME Sniffing)
    Header set X-Content-Type-Options "nosniff"

    # Previene que tu sitio sea puesto en un iframe (Evita Clickjacking)
    Header set X-Frame-Options "SAMEORIGIN"

    # Controla cuánta info de la URL se envía a otros sitios
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS: Fuerza el uso de HTTPS (Activar solo si tienes SSL configurado)
    # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Desactiva la filtración de información de LiteSpeed/Apache
    Header unset X-Powered-By
</IfModule>

# ----------------------------------------------------------------------
# 3. PROTECCIÓN DE ARCHIVOS CRÍTICOS
# ----------------------------------------------------------------------

# Bloquear TODOS los dotfiles: .env, .env.local, .git, .gitignore,
# .htpasswd, .ssh, .idea, .vscode, etc.
<FilesMatch "^\.">
    Order deny,allow
    Deny from all
</FilesMatch>

# Bloquear extensiones de configuración y datos sensibles
<FilesMatch "\.(env|sql|log|bak|config|lock|sh|bash|key|pem|pfx|p12)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Bloquear archivos de configuración por nombre exacto
<FilesMatch "^(composer\.json|composer\.lock|package\.json|package-lock\.json|webpack\.config\.js|vite\.config\.js|dockerfile|docker-compose\.yml|phpunit\.xml)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Desactiva los ETags para evitar fuga de Inodos (Fallo CVE-2003-1418)
FileETag None

# Desactiva el listado de directorios (Si no hay index.php, no muestra los archivos)
Options -Indexes