{
  "name": "suzuma/szm-core",
  "description": "Un framework de PHP minimalista y de alto rendimiento, diseñado para aplicaciones web escalables",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Noe Cazarez Camargo",
      "email": "suzuma@gmail.com"
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "require": {
    "php": "^8.3",
    "illuminate/database": "^13.3",
    "illuminate/events": "^13.3",
    "illuminate/pagination": "^13.3",
    "monolog/monolog": "^3.10",
    "phroute/phroute": "^2.2",
    "twig/twig": "^3.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Core\\": "core/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyze app core",
    "format": "php-cs-fixer fix",
    "serve": "php -S localhost:8000 index.php"
  }
}
