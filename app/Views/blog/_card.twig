{#
  _card.twig — tarjeta de post reutilizable.
  Variables: post (App\Models\Post), size ('full'|'compact')
#}
{% set size = size|default('compact') %}

<article class="blog-card {{ size == 'full' ? 'blog-card--full' : '' }}"
         aria-label="Artículo: {{ post.title|e }}">

    {# Imagen destacada #}
    {% if post.featured_image %}
    <a href="/blog/{{ post.slug }}" class="blog-card__img-wrap" tabindex="-1" aria-hidden="true">
        <img src="{{ asset(post.featured_image) }}"
             alt="{{ post.featured_image_alt ?: post.title }}"
             class="blog-card__img"
             loading="lazy"
             width="800" height="450">
    </a>
    {% else %}
    <div class="blog-card__img-placeholder" aria-hidden="true">
        <svg fill="none" viewBox="0 0 48 48" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                  d="M4 8h40M4 8v32h40V8M4 8l12 14 8-8 12 14 8-10"/>
        </svg>
    </div>
    {% endif %}

    <div class="blog-card__body">

        {# Categoría #}
        {% if post.category %}
        <a href="/blog/categoria/{{ post.category.slug }}" class="blog-card__cat">
            {{ post.category.name }}
        </a>
        {% endif %}

        {# Título #}
        <h2 class="blog-card__title {{ size == 'full' ? 'blog-card__title--lg' : '' }}">
            <a href="/blog/{{ post.slug }}">{{ post.title }}</a>
        </h2>

        {# Extracto #}
        {% if size == 'full' %}
        <p class="blog-card__excerpt">{{ post.excerptText }}</p>
        {% endif %}

        {# Meta: autor + fecha + lectura #}
        <div class="blog-card__meta">
            <span>{{ post.author.name }}</span>
            <span class="blog-card__sep" aria-hidden="true">·</span>
            <time datetime="{{ post.published_at ? post.published_at|date('Y-m-d') : '' }}">
                {{ post.published_at ? post.published_at|date('d M Y') : '—' }}
            </time>
            <span class="blog-card__sep" aria-hidden="true">·</span>
            <span>{{ post.reading_time }} min lectura</span>
        </div>

        {# Tags #}
        {% if post.tags is not empty %}
        <div class="blog-card__tags" aria-label="Etiquetas">
            {% for tag in post.tags|slice(0, 3) %}
            <a href="/blog/tag/{{ tag.slug }}" class="blog-tag">#{{ tag.name }}</a>
            {% endfor %}
        </div>
        {% endif %}

    </div>
</article>