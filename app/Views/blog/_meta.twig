{#
  _meta.twig — meta tags SEO + Open Graph para todas las vistas del blog.
  Variables esperadas (desde el controlador):
    page_title       string  — título de la página
    meta_description string  — descripción (max ~160 chars)
    og_image         string|null — URL absoluta de imagen destacada
    canonical_url    string|null — URL canónica del post
    app_name         string  — global Twig desde TwigFactory
#}
<meta name="description" content="{{ meta_description|default('')|e }}">

{% if canonical_url is defined and canonical_url %}
<link rel="canonical" href="{{ canonical_url }}">
{% endif %}

{# ── Open Graph ──────────────────────────────────────────────────────── #}
<meta property="og:type"        content="{{ post is defined ? 'article' : 'website' }}">
<meta property="og:site_name"   content="{{ app_name }}">
<meta property="og:title"       content="{{ page_title|default(app_name)|e }}">
<meta property="og:description" content="{{ meta_description|default('')|e }}">
{% if og_image is defined and og_image %}
<meta property="og:image"       content="{{ og_image }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{% endif %}
{% if canonical_url is defined and canonical_url %}
<meta property="og:url"         content="{{ canonical_url }}">
{% endif %}

{# ── Twitter Card ────────────────────────────────────────────────────── #}
<meta name="twitter:card"        content="{{ og_image is defined and og_image ? 'summary_large_image' : 'summary' }}">
<meta name="twitter:title"       content="{{ page_title|default(app_name)|e }}">
<meta name="twitter:description" content="{{ meta_description|default('')|e }}">
{% if og_image is defined and og_image %}
<meta name="twitter:image"       content="{{ og_image }}">
{% endif %}

{# ── Artículo (solo en show.twig) ────────────────────────────────────── #}
{% if post is defined %}
<meta property="article:published_time" content="{{ post.published_at ? post.published_at|date('c') : '' }}">
<meta property="article:modified_time"  content="{{ post.updated_at ? post.updated_at|date('c') : '' }}">
{% if post.category %}
<meta property="article:section" content="{{ post.category.name|e }}">
{% endif %}
{% for tag in post.tags %}
<meta property="article:tag" content="{{ tag.name|e }}">
{% endfor %}
{% endif %}