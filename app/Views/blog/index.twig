{% extends 'layouts/app.twig' %}

{% block title %}{{ page_title }} — {{ app_name }}{% endblock %}

{% block head %}
{% include 'blog/_meta.twig' %}
<link rel="stylesheet" href="{{ asset('public/css/blog.css') }}">
{% endblock %}

{% block page_title %}{{ page_title }}{% endblock %}

{% block breadcrumbs %}
<nav class="breadcrumbs" aria-label="Ruta de navegación">
    <ol>
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        {% if active_category is defined %}
            <li class="breadcrumb-item"><a href="/blog">Blog</a></li>
            <li class="breadcrumb-item breadcrumb-active">{{ active_category.name }}</li>
        {% elseif active_tag is defined %}
            <li class="breadcrumb-item"><a href="/blog">Blog</a></li>
            <li class="breadcrumb-item breadcrumb-active">#{{ active_tag.name }}</li>
        {% else %}
            <li class="breadcrumb-item breadcrumb-active">Blog</li>
        {% endif %}
    </ol>
</nav>
{% endblock %}

{% block content %}

{# ── Post destacado (solo en página 1 sin filtros) ─────────────────────── #}
{% if featured %}
<article class="blog-featured" aria-label="Artículo destacado: {{ featured.title }}">
    {% if featured.featured_image %}
    <a href="/blog/{{ featured.slug }}" class="blog-featured__img-wrap" tabindex="-1">
        <img src="{{ asset(featured.featured_image) }}"
             alt="{{ featured.featured_image_alt ?: featured.title }}"
             class="blog-featured__img"
             loading="eager"
             width="1200" height="500">
    </a>
    {% endif %}
    <div class="blog-featured__body">
        {% if featured.category %}
        <a href="/blog/categoria/{{ featured.category.slug }}" class="blog-card__cat">
            {{ featured.category.name }}
        </a>
        {% endif %}
        <h1 class="blog-featured__title">
            <a href="/blog/{{ featured.slug }}">{{ featured.title }}</a>
        </h1>
        <p class="blog-featured__excerpt">{{ featured.excerptText }}</p>
        <div class="blog-card__meta">
            <span>{{ featured.author.name }}</span>
            <span class="blog-card__sep" aria-hidden="true">·</span>
            <time datetime="{{ featured.published_at ? featured.published_at|date('Y-m-d') : '' }}">
                {{ featured.published_at ? featured.published_at|date('d M Y') : '' }}
            </time>
            <span class="blog-card__sep" aria-hidden="true">·</span>
            <span>{{ featured.reading_time }} min lectura</span>
        </div>
        <a href="/blog/{{ featured.slug }}" class="blog-read-more">Leer artículo →</a>
    </div>
</article>
{% endif %}

{# ── Barra de filtro / búsqueda ────────────────────────────────────────── #}
<div class="blog-topbar">
    <form method="GET" action="/blog" role="search" aria-label="Buscar en el blog"
          style="display:flex;gap:.5rem;align-items:center">
        <input type="search" name="q" value="{{ search }}"
               placeholder="Buscar artículos…"
               class="blog-search-input"
               aria-label="Término de búsqueda">
        <button type="submit" class="btn" style="width:auto;padding:.5rem 1rem;font-size:.875rem">
            Buscar
        </button>
        {% if search %}
        <a href="/blog" class="btn-outline" style="padding:.45rem .875rem;font-size:.875rem;text-decoration:none">
            Limpiar
        </a>
        {% endif %}
    </form>
    <p class="blog-topbar__count">
        {{ total }} artículo{{ total != 1 ? 's' : '' }}
        {% if active_category is defined %} en <strong>{{ active_category.name }}</strong>{% endif %}
        {% if active_tag is defined %} con <strong>#{{ active_tag.name }}</strong>{% endif %}
        {% if search %} para "<strong>{{ search }}</strong>"{% endif %}
    </p>
</div>

{# ── Grid de posts + Sidebar ───────────────────────────────────────────── #}
<div class="blog-layout">

    <div class="blog-grid-wrap">
        {% if posts is empty %}
        <div class="blog-empty">
            <p>No hay artículos que coincidan.</p>
            <a href="/blog" class="btn-outline" style="margin-top:1rem;display:inline-block;padding:.55rem 1rem;text-decoration:none">
                Ver todos
            </a>
        </div>
        {% else %}
        <div class="blog-grid" role="list">
            {% for post in posts %}
            <div role="listitem">
                {% include 'blog/_card.twig' with {post: post, size: 'compact'} %}
            </div>
            {% endfor %}
        </div>

        {# ── Paginación ────────────────────────────────────────────── #}
        {% if total_pages > 1 %}
        <nav class="blog-pagination" aria-label="Paginación del blog">
            {% if page > 1 %}
            <a href="?page={{ page - 1 }}&q={{ search }}" class="btn-outline" style="text-decoration:none;padding:.5rem .875rem">
                ← Anterior
            </a>
            {% endif %}
            <span class="blog-pagination__info">
                Página {{ page }} de {{ total_pages }}
            </span>
            {% if page < total_pages %}
            <a href="?page={{ page + 1 }}&q={{ search }}" class="btn-outline" style="text-decoration:none;padding:.5rem .875rem">
                Siguiente →
            </a>
            {% endif %}
        </nav>
        {% endif %}
        {% endif %}
    </div>

    {# ── Sidebar ────────────────────────────────────────────────────── #}
    {% include 'blog/_sidebar.twig' %}

</div>

{% endblock %}