{% extends 'layouts/app.twig' %}

{% block title %}{{ post.seoTitle }} — {{ app_name }}{% endblock %}

{% block head %}
{% include 'blog/_meta.twig' %}
<link rel="stylesheet" href="{{ asset('public/css/blog.css') }}">
{# Barra de progreso de lectura fija en el topbar #}
<style>
#read-progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    width: 0%;
    background: var(--sky, #00BFFF);
    z-index: 9999;
    transition: width .1s linear;
}
</style>
{% endblock %}

{% block breadcrumbs %}
<nav class="breadcrumbs" aria-label="Ruta de navegación">
    <ol>
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/blog">Blog</a></li>
        {% if post.category %}
        <li class="breadcrumb-item">
            <a href="/blog/categoria/{{ post.category.slug }}">{{ post.category.name }}</a>
        </li>
        {% endif %}
        <li class="breadcrumb-item breadcrumb-active">{{ post.title|slice(0, 40) }}{% if post.title|length > 40 %}…{% endif %}</li>
    </ol>
</nav>
{% endblock %}

{% block content %}

{# Barra de progreso de lectura #}
<div id="read-progress" role="progressbar" aria-label="Progreso de lectura"
     aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>

<div class="blog-layout blog-layout--article">

    {# ── Artículo ────────────────────────────────────────────────────── #}
    <article class="blog-article" id="article-body">

        {# Cabecera #}
        <header class="blog-article__header">

            {% if post.category %}
            <a href="/blog/categoria/{{ post.category.slug }}" class="blog-card__cat">
                {{ post.category.name }}
            </a>
            {% endif %}

            <h1 class="blog-article__title">{{ post.title }}</h1>

            <div class="blog-article__meta">
                <div class="blog-article__author">
                    <div class="blog-author-avatar" aria-hidden="true">
                        {{ post.author.name|slice(0,1)|upper }}
                    </div>
                    <div>
                        <span class="blog-article__author-name">{{ post.author.name }}</span>
                        <span class="blog-article__date">
                            <time datetime="{{ post.published_at ? post.published_at|date('Y-m-d') : '' }}">
                                {{ post.published_at ? post.published_at|date('d M Y') : '' }}
                            </time>
                        </span>
                    </div>
                </div>
                <div class="blog-article__reading">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    {{ post.reading_time }} min lectura
                    <span class="blog-article__views" aria-label="{{ post.views }} vistas">
                        · {{ post.views }} vistas
                    </span>
                </div>
            </div>

            {# Imagen destacada #}
            {% if post.featured_image %}
            <figure class="blog-article__hero">
                <img src="{{ asset(post.featured_image) }}"
                     alt="{{ post.featured_image_alt ?: post.title }}"
                     class="blog-article__hero-img"
                     loading="eager"
                     width="1200" height="630">
            </figure>
            {% endif %}

        </header>

        {# ── Contenido principal ──────────────────────────────────── #}
        <div class="blog-prose" id="prose-content">
            {{ post.content|raw }}
        </div>

        {# ── Footer del artículo: tags + compartir ──────────────── #}
        <footer class="blog-article__footer">

            {% if post.tags is not empty %}
            <div class="blog-article__tags" aria-label="Etiquetas">
                {% for tag in post.tags %}
                <a href="/blog/tag/{{ tag.slug }}" class="blog-tag">#{{ tag.name }}</a>
                {% endfor %}
            </div>
            {% endif %}

            {# Botones de compartir — enlaces nativos, sin SDK #}
            <div class="blog-share" aria-label="Compartir artículo">
                <span class="blog-share__label">Compartir:</span>
                <a href="https://twitter.com/intent/tweet?text={{ post.title|url_encode }}&url={{ canonical_url|url_encode }}"
                   class="blog-share__btn blog-share__btn--twitter"
                   target="_blank" rel="noopener noreferrer"
                   aria-label="Compartir en Twitter/X">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L2.25 2.25h6.844l4.258 5.63 4.892-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
                    </svg>
                </a>
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ canonical_url|url_encode }}"
                   class="blog-share__btn blog-share__btn--facebook"
                   target="_blank" rel="noopener noreferrer"
                   aria-label="Compartir en Facebook">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                </a>
                <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ canonical_url|url_encode }}"
                   class="blog-share__btn blog-share__btn--linkedin"
                   target="_blank" rel="noopener noreferrer"
                   aria-label="Compartir en LinkedIn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                </a>
                <button type="button" class="blog-share__btn blog-share__btn--copy"
                        data-url="{{ canonical_url }}"
                        aria-label="Copiar enlace">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                </button>
            </div>
        </footer>

    </article>

    {# ── Sidebar ────────────────────────────────────────────────────── #}
    {% include 'blog/_sidebar.twig' %}

</div>

{# ── Artículos relacionados ────────────────────────────────────────────── #}
{% if related is not empty %}
<section class="blog-related" aria-label="Artículos relacionados">
    <h2 class="blog-related__title">Artículos relacionados</h2>
    <div class="blog-related__grid">
        {% for rel in related %}
        {% include 'blog/_card.twig' with {post: rel, size: 'compact'} %}
        {% endfor %}
    </div>
</section>
{% endif %}

{# Botón volver arriba #}
<button class="blog-back-top" id="back-to-top" aria-label="Volver al inicio">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
    </svg>
</button>

{% endblock %}

{% block scripts %}
<script>
/* ── Barra de progreso de lectura ────────────────────────────────────── */
(function () {
    const bar    = document.getElementById('read-progress');
    const prose  = document.getElementById('prose-content');
    if (!bar || !prose) return;

    function updateProgress() {
        const rect  = prose.getBoundingClientRect();
        const total = rect.height - window.innerHeight;
        if (total <= 0) { bar.style.width = '100%'; return; }
        const scrolled = Math.max(0, -rect.top);
        const pct = Math.min(100, Math.round((scrolled / total) * 100));
        bar.style.width = pct + '%';
        bar.setAttribute('aria-valuenow', String(pct));
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
})();

/* ── Botón copiar enlace ─────────────────────────────────────────────── */
document.querySelector('.blog-share__btn--copy')?.addEventListener('click', function () {
    const url = this.dataset.url;
    navigator.clipboard?.writeText(url).then(() => {
        const orig = this.innerHTML;
        this.innerHTML = '<svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(() => { this.innerHTML = orig; }, 2000);
    });
});

/* ── Tabla de contenidos auto-generada ───────────────────────────────── */
(function () {
    const prose = document.getElementById('prose-content');
    if (!prose) return;

    const headings = Array.from(prose.querySelectorAll('h2, h3'));
    if (headings.length < 2) return;

    // Asignar IDs únicos a cada encabezado
    const seen = {};
    headings.forEach(h => {
        const base = h.textContent.trim().toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-');
        seen[base] = (seen[base] || 0) + 1;
        h.id = 'h-' + base + (seen[base] > 1 ? '-' + seen[base] : '');
    });

    // Construir el ToC
    const nav  = document.createElement('nav');
    nav.className = 'blog-toc';
    nav.setAttribute('aria-label', 'Tabla de contenidos');

    const title = document.createElement('p');
    title.className = 'blog-toc__title';
    title.textContent = 'Contenido';
    nav.appendChild(title);

    const ul = document.createElement('ul');
    ul.className = 'blog-toc__list';

    headings.forEach(h => {
        const li = document.createElement('li');
        li.className = 'blog-toc__item' + (h.tagName === 'H3' ? ' blog-toc__item--h3' : '');
        const a = document.createElement('a');
        a.className = 'blog-toc__link';
        a.href = '#' + h.id;
        a.textContent = h.textContent.trim();
        a.addEventListener('click', e => {
            e.preventDefault();
            document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.replaceState(null, '', '#' + h.id);
        });
        li.appendChild(a);
        ul.appendChild(li);
    });

    nav.appendChild(ul);
    prose.insertBefore(nav, prose.firstChild);

    // Resaltar sección activa al hacer scroll
    const links = ul.querySelectorAll('.blog-toc__link');
    const io = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                links.forEach(l => l.classList.remove('active'));
                ul.querySelector(`a[href="#${entry.target.id}"]`)?.classList.add('active');
            }
        });
    }, { rootMargin: '0px 0px -65% 0px', threshold: 0 });

    headings.forEach(h => io.observe(h));
})();

/* ── Botón volver arriba ─────────────────────────────────────────────── */
(function () {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    window.addEventListener('scroll', () => {
        btn.classList.toggle('visible', window.scrollY > 450);
    }, { passive: true });

    btn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
})();
</script>
{% endblock %}