{% import 'components/alert.twig' as alert %}

<!DOCTYPE html>
<html lang="es" id="htmlRoot">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('public/assets/logo.png') }}">
    <link rel="stylesheet" href="{{ asset('public/css/app.css') }}">
    {% block head %}{% endblock %}
</head>
<body>

{# ── Toast container (T2) ────────────────────────────────────────────── #}
<div id="toast-container" aria-live="polite"></div>

<div class="layout">

    {# ── Sidebar ──────────────────────────────────────────────────── #}
    <aside class="sidebar" id="appSidebar">
        <div class="sidebar-brand">
            <img src="{{ asset('public/assets/logo.png') }}" alt="{{ app_name }}">
        </div>

        {# Botón de colapso (desktop) #}
        <button class="sidebar-collapse-btn" id="sidebarCollapseBtn"
                aria-label="Colapsar menú" title="Colapsar menú">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 19l-7-7 7-7"/>
            </svg>
        </button>

        <ul class="nav" role="navigation" aria-label="Menú principal">
            <li class="nav-item {{ _uri == '/' ? 'active' : '' }}">
                <a href="/" data-tooltip="Inicio">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    <span class="nav-label">Inicio</span>
                </a>
            </li>
            {% if auth_role == 'admin' %}
            <li class="nav-item {{ _uri starts with '/admin/users' ? 'active' : '' }}">
                <a href="/admin/users" data-tooltip="Usuarios">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="nav-label">Usuarios</span>
                </a>
            </li>
            <li class="nav-item {{ _uri == '/admin/audit-log' ? 'active' : '' }}">
                <a href="/admin/audit-log" data-tooltip="Audit Log">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                    </svg>
                    <span class="nav-label">Audit Log</span>
                </a>
            </li>
            <li class="nav-item {{ _uri starts with '/admin/waf' ? 'active' : '' }}">
                <a href="/admin/waf" data-tooltip="WAF">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                    <span class="nav-label">WAF</span>
                </a>
            </li>
            <li class="nav-item {{ _uri starts with '/admin/config' ? 'active' : '' }}">
                <a href="/admin/config" data-tooltip="Configuración">
                    <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="nav-label">Configuración</span>
                </a>
            </li>
            {% endif %}
            {% block nav_extra %}{% endblock %}
        </ul>

        <div class="sidebar-footer">
            <div class="sidebar-footer-info">
                <span class="user-name">{{ auth_user_name }}</span>
                <span class="user-role">{{ auth_role }}</span>
            </div>
            <form method="POST" action="/logout">
                {{ csrf_field()|raw }}
                <button type="submit" class="logout-btn">Cerrar sesión</button>
            </form>
        </div>
    </aside>

    {# ── Contenido principal ───────────────────────────────────────── #}
    <div class="main">

        <header class="topbar">
            <div class="topbar-left">
                {# Botón hamburguesa (mobile) #}
                <button class="hamburger" id="sidebarToggle" aria-label="Menú">
                    <span></span><span></span><span></span>
                </button>
                <span class="topbar-title">{% block page_title %}{% endblock %}</span>
            </div>
            <div class="topbar-actions">
                {% block topbar_actions %}{% endblock %}
                {# Toggle dark / light mode #}
                <button class="theme-toggle" id="themeToggle"
                        aria-label="Cambiar tema" title="Cambiar tema claro/oscuro">
                    <span id="themeIcon">🌙</span>
                </button>
            </div>
        </header>

        {# ── Breadcrumbs ──────────────────────────────────────────── #}
        {% block breadcrumbs %}{% endblock %}

        <main class="content">

            {# Flash messages via componente #}
            {% if has_flash('success') %}{{ alert.render('success', flash('success'))|raw }}{% endif %}
            {% if has_flash('error') %}{{ alert.render('error', flash('error'))|raw }}{% endif %}
            {% if has_flash('warning') %}{{ alert.render('warning', flash('warning'))|raw }}{% endif %}
            {% if has_flash('info') %}{{ alert.render('info', flash('info'))|raw }}{% endif %}

            {% block content %}{% endblock %}

        </main>
    </div>

</div>

{# ── Overlay mobile ───────────────────────────────────────────────────── #}
<div class="sidebar-overlay" id="sidebarOverlay"></div>

{# ── Modal: sesión por expirar ──────────────────────────────────────── #}
<div id="session-modal" class="session-modal" hidden role="dialog" aria-modal="true" aria-labelledby="session-modal-title">
    <div class="session-modal-box">
        <h3 id="session-modal-title">Sesión por expirar</h3>
        <p>Tu sesión se cerrará en <strong id="session-countdown">5:00</strong>.<br>¿Deseas continuar?</p>
        <div class="session-modal-actions">
            <button type="button" id="session-extend" class="btn">Continuar</button>
            <form method="POST" action="/logout" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token() }}">
                <button type="submit" class="btn-outline">Cerrar sesión</button>
            </form>
        </div>
    </div>
</div>

<script nonce="{{ csp_nonce }}">
/* ── Sidebar ─────────────────────────────────────────────────────────── */
const sidebar      = document.getElementById('appSidebar');
const overlay      = document.getElementById('sidebarOverlay');
const mobileToggle = document.getElementById('sidebarToggle');
const collapseBtn  = document.getElementById('sidebarCollapseBtn');

/* Mobile: abrir/cerrar */
function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('visible');
}
mobileToggle?.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    overlay.classList.toggle('visible');
});
overlay?.addEventListener('click', closeSidebar);

/* Desktop: colapsar/expandir con persistencia */
const COLLAPSE_KEY = 'szm-sidebar-collapsed';

function applySidebarState(collapsed, animate) {
    if (!animate) sidebar.style.transition = 'none';
    sidebar.classList.toggle('collapsed', collapsed);
    if (!animate) requestAnimationFrame(() => { sidebar.style.transition = ''; });
    try { localStorage.setItem(COLLAPSE_KEY, collapsed ? '1' : '0'); } catch {}
}

/* Restaurar estado guardado sin animación */
const savedCollapsed = localStorage.getItem(COLLAPSE_KEY) === '1';
applySidebarState(savedCollapsed, false);

collapseBtn?.addEventListener('click', () => {
    applySidebarState(!sidebar.classList.contains('collapsed'), true);
});

/* ── Loading state en formularios ────────────────────────────────────── */
document.querySelectorAll('form').forEach(form => {
    form.addEventListener('submit', () => {
        form.querySelectorAll('button[type="submit"], button:not([type])').forEach(btn => {
            btn.classList.add('btn-loading');
            btn.disabled = true;
        });
    });
});

/* ── Toast API ───────────────────────────────────────────────────────── */
window.toast = function(message, type = 'info', duration = 4000) {
    const container = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = `toast toast-${type}`;
    t.setAttribute('role', 'status');
    t.innerHTML = `<span>${message}</span><button class="toast-close" onclick="this.parentElement.remove()">×</button>`;
    container.appendChild(t);
    requestAnimationFrame(() => t.classList.add('toast-show'));
    if (duration > 0) setTimeout(() => { t.classList.remove('toast-show'); setTimeout(() => t.remove(), 300); }, duration);
};

/* ── Session timeout warning ─────────────────────────────────────────── */
(function () {
    const LIFETIME_MS = {{ session_lifetime }} * 60 * 1000;
    const WARN_MS     = Math.min(5 * 60 * 1000, LIFETIME_MS * 0.2);
    const modal       = document.getElementById('session-modal');
    const countdown   = document.getElementById('session-countdown');
    const extendBtn   = document.getElementById('session-extend');
    let warnTimer, countInterval;

    function fmt(s) {
        const m = Math.floor(s / 60);
        return m + ':' + String(s % 60).padStart(2, '0');
    }

    function startCountdown() {
        let remaining = Math.round(WARN_MS / 1000);
        if (countdown) countdown.textContent = fmt(remaining);
        if (modal) modal.hidden = false;
        clearInterval(countInterval);
        countInterval = setInterval(() => {
            remaining--;
            if (countdown) countdown.textContent = fmt(remaining);
            if (remaining <= 0) {
                clearInterval(countInterval);
                window.location.href = '/login';
            }
        }, 1000);
    }

    function resetTimer() {
        clearTimeout(warnTimer);
        clearInterval(countInterval);
        if (modal) modal.hidden = true;
        warnTimer = setTimeout(startCountdown, LIFETIME_MS - WARN_MS);
    }

    extendBtn?.addEventListener('click', () => {
        fetch('/session-keepalive').finally(resetTimer);
    });

    resetTimer();
})();
</script>

<script nonce="{{ csp_nonce }}">
/* ── Dark mode ───────────────────────────────────────────────────────── */
(function () {
    const root   = document.documentElement;
    const btn    = document.getElementById('themeToggle');
    const icon   = document.getElementById('themeIcon');
    const KEY    = 'szm-theme';

    function apply(theme) {
        root.setAttribute('data-theme', theme);
        if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
        try { localStorage.setItem(KEY, theme); } catch {}
    }

    // Restaurar preferencia guardada; si no hay, seguir al sistema
    const saved = (() => { try { return localStorage.getItem(KEY); } catch {} return null; })();
    if (saved === 'dark' || saved === 'light') {
        apply(saved);
    } else {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (icon) icon.textContent = prefersDark ? '☀️' : '🌙';
    }

    btn?.addEventListener('click', () => {
        const current = root.getAttribute('data-theme');
        if (current === 'dark')  apply('light');
        else                     apply('dark');
    });
})();

/* ── Modal API ───────────────────────────────────────────────────────── */
window.Modal = {
    open(id) {
        const el = document.getElementById('modal-' + id);
        if (!el) return;
        el.classList.add('open');
        document.body.style.overflow = 'hidden';
        // Focus al primer elemento interactivo dentro del modal
        setTimeout(() => {
            const focusable = el.querySelector('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
            focusable?.focus();
        }, 50);
        // Cerrar con Escape
        el._escHandler = (e) => { if (e.key === 'Escape') Modal.close(id); };
        document.addEventListener('keydown', el._escHandler);
    },

    close(id) {
        const el = document.getElementById('modal-' + id);
        if (!el) return;
        el.classList.remove('open');
        document.body.style.overflow = '';
        if (el._escHandler) {
            document.removeEventListener('keydown', el._escHandler);
            delete el._escHandler;
        }
    },

    closeAll() {
        document.querySelectorAll('.modal-backdrop.open').forEach(el => {
            el.classList.remove('open');
            if (el._escHandler) {
                document.removeEventListener('keydown', el._escHandler);
                delete el._escHandler;
            }
        });
        document.body.style.overflow = '';
    },

    /**
     * Diálogo de confirmación programático.
     * Retorna una Promise que resuelve true (confirmar) o false (cancelar).
     *
     * Ejemplo:
     *   const ok = await Modal.confirm('¿Eliminar este registro?');
     *   if (ok) fetch('/admin/items/42', { method: 'DELETE' });
     */
    confirm(message, options = {}) {
        return new Promise(resolve => {
            const id  = '__modal_confirm_' + Date.now();
            const ok  = options.okLabel     ?? 'Confirmar';
            const cancel = options.cancelLabel ?? 'Cancelar';
            const title  = options.title       ?? 'Confirmar acción';

            const div = document.createElement('div');
            div.id = 'modal-' + id;
            div.className = 'modal-backdrop';
            div.setAttribute('role', 'dialog');
            div.setAttribute('aria-modal', 'true');
            div.innerHTML = `
                <div class="modal modal-sm">
                    <header class="modal-header">
                        <h3 class="modal-title">${title}</h3>
                        <button class="modal-close" type="button" aria-label="Cerrar">×</button>
                    </header>
                    <div class="modal-body"><p>${message}</p></div>
                    <footer class="modal-footer">
                        <button class="btn btn-ghost" type="button" data-action="cancel">${cancel}</button>
                        <button class="btn btn-danger" type="button" data-action="ok">${ok}</button>
                    </footer>
                </div>`;

            document.body.appendChild(div);

            function done(result) {
                Modal.close(id);
                setTimeout(() => div.remove(), 200);
                resolve(result);
            }

            div.querySelector('[data-action="ok"]').addEventListener('click', () => done(true));
            div.querySelector('[data-action="cancel"]').addEventListener('click', () => done(false));
            div.querySelector('.modal-close').addEventListener('click', () => done(false));
            div.addEventListener('click', e => { if (e.target === div) done(false); });

            Modal.open(id);
        });
    }
};
</script>

{% block scripts %}{% endblock %}
</body>
</html>