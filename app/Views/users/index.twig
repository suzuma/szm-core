{% extends 'layouts/app.twig' %}

{% block title %}Usuarios — {{ app_name }}{% endblock %}
{% block page_title %}Gestión de Usuarios{% endblock %}

{# ── Tailwind con preflight desactivado para no romper el design system ── #}
{% block head %}
<script>
    window.tailwind = { corePlugins: { preflight: false } };
</script>
<script src="https://cdn.tailwindcss.com"></script>
<style>
    /* Overrides puntuales para la tabla de usuarios */
    .user-table { width:100%; border-collapse:collapse; }
    .user-table th { background:var(--surface-2,#f1f5f9); color:var(--muted,#64748b); font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; padding:.625rem 1rem; text-align:left; border-bottom:1px solid var(--border,#e2e8f0); }
    .user-table td { padding:.75rem 1rem; border-bottom:1px solid var(--border,#e2e8f0); font-size:.875rem; vertical-align:middle; }
    .user-table tbody tr:last-child td { border-bottom:none; }
    .user-table tbody tr { transition:background .15s; }
    .user-table tbody tr:hover { background:var(--surface-2,#f8fafc); }

    /* Modal */
    .u-modal-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.45); display:flex; align-items:center; justify-content:center; z-index:50; opacity:0; pointer-events:none; transition:opacity .2s; }
    .u-modal-backdrop.open { opacity:1; pointer-events:all; }
    .u-modal-box { background:#fff; border-radius:.75rem; width:100%; max-width:30rem; padding:1.75rem; transform:translateY(1rem) scale(.97); transition:transform .25s, opacity .25s; opacity:0; box-shadow:0 20px 60px rgba(0,0,0,.18); }
    .u-modal-backdrop.open .u-modal-box { transform:translateY(0) scale(1); opacity:1; }

    /* Campos del modal */
    .u-field { margin-bottom:1rem; }
    .u-field label { display:block; font-size:.8125rem; font-weight:600; margin-bottom:.35rem; color:var(--fg,#1e293b); }
    .u-input { width:100%; padding:.6rem .875rem; border:1px solid var(--border,#cbd5e1); border-radius:.5rem; font-size:.875rem; outline:none; transition:border-color .15s, box-shadow .15s; background:#fff; }
    .u-input:focus { border-color:var(--primary,#00BFFF); box-shadow:0 0 0 3px rgba(0,191,255,.15); }
    .u-input.invalid { border-color:#ef4444; box-shadow:0 0 0 3px rgba(239,68,68,.1); }
    .u-field-error { color:#ef4444; font-size:.75rem; margin-top:.3rem; display:none; }
    .u-field-error.show { display:block; }

    /* Botones de acción compactos */
    .btn-icon { display:inline-flex; align-items:center; justify-content:center; width:2rem; height:2rem; border-radius:.375rem; border:none; cursor:pointer; transition:background .15s, transform .1s; }
    .btn-icon:active { transform:scale(.93); }
    .btn-icon-edit { background:#dbeafe; color:#1d4ed8; }
    .btn-icon-edit:hover { background:#bfdbfe; }
    .btn-icon-toggle { background:#dcfce7; color:#15803d; }
    .btn-icon-toggle.is-inactive { background:#fef3c7; color:#b45309; }
    .btn-icon-toggle:hover { filter:brightness(.93); }
    .btn-icon-delete { background:#fee2e2; color:#dc2626; }
    .btn-icon-delete:hover { background:#fecaca; }

    /* Toast */
    .u-toast-wrap { position:fixed; bottom:1.5rem; right:1.5rem; display:flex; flex-direction:column; gap:.5rem; z-index:100; }
    .u-toast { display:flex; align-items:center; gap:.625rem; padding:.75rem 1.1rem; border-radius:.5rem; font-size:.875rem; font-weight:500; color:#fff; min-width:240px; max-width:360px; box-shadow:0 8px 24px rgba(0,0,0,.15); animation:toastIn .3s ease; }
    .u-toast.success { background:#16a34a; }
    .u-toast.error   { background:#dc2626; }
    @keyframes toastIn { from { opacity:0; transform:translateY(.5rem); } to { opacity:1; transform:translateY(0); } }

    /* Estado vacío */
    .u-empty { display:flex; flex-direction:column; align-items:center; padding:3rem 1rem; gap:.75rem; color:var(--muted); }
    .u-empty svg { width:3rem; height:3rem; opacity:.35; }

    /* Strength bar */
    .pw-strength-bar { height:4px; background:#e2e8f0; border-radius:2px; margin-top:.4rem; overflow:hidden; }
    .pw-strength-fill { height:100%; width:0; border-radius:2px; transition:width .25s, background .25s; }
    .pw-label { font-size:.7rem; margin-top:.25rem; font-weight:600; }
</style>
{% endblock %}

{% block breadcrumbs %}
<nav class="breadcrumbs" aria-label="Ruta de navegación">
    <ol>
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item breadcrumb-active">Usuarios</li>
    </ol>
</nav>
{% endblock %}

{% block content %}

{# ── Header ─────────────────────────────────────────────────────────────── #}
<div class="flex items-center justify-between mb-5 gap-3 flex-wrap">
    <div>
        <p class="text-sm" style="color:var(--muted)">
            {{ total }} usuario{{ total != 1 ? 's' : '' }} en el sistema
        </p>
    </div>
    <button id="btn-new-user" type="button"
            class="btn"
            style="width:auto;padding:.6rem 1.25rem"
            aria-label="Crear nuevo usuario">
        <span aria-hidden="true">＋</span> Nuevo usuario
    </button>
</div>

{# ── Filtros — una sola fila horizontal ───────────────────────────────────── #}
<div class="card" style="margin-bottom:1.25rem;padding:.75rem 1.25rem">
    <form method="GET" action="/admin/users"
          style="display:flex;align-items:flex-end;gap:.75rem;overflow-x:auto"
          role="search" aria-label="Filtrar usuarios">

        {# Búsqueda — ocupa el espacio sobrante #}
        <div style="flex:1;min-width:160px;max-width:320px">
            <label for="f-q" style="display:block;font-size:.75rem;font-weight:600;margin-bottom:.3rem;color:var(--muted)">Buscar</label>
            <input id="f-q" type="search" name="q" value="{{ search }}"
                   placeholder="Nombre o correo…"
                   class="u-input" autocomplete="off" style="height:2.25rem;padding:.4rem .75rem">
        </div>

        {# Rol #}
        <div style="width:150px;flex-shrink:0">
            <label for="filter-role" style="display:block;font-size:.75rem;font-weight:600;margin-bottom:.3rem;color:var(--muted)">Rol</label>
            <select id="filter-role" name="role_id" class="u-input" style="height:2.25rem;padding:.4rem .75rem">
                <option value="">Todos</option>
                {% for role in roles %}
                    <option value="{{ role.id }}" {{ filter_role == role.id ? 'selected' : '' }}>
                        {{ role.label }}
                    </option>
                {% endfor %}
            </select>
        </div>

        {# Estado #}
        <div style="width:120px;flex-shrink:0">
            <label for="f-status" style="display:block;font-size:.75rem;font-weight:600;margin-bottom:.3rem;color:var(--muted)">Estado</label>
            <select id="f-status" name="status" class="u-input" style="height:2.25rem;padding:.4rem .75rem">
                <option value="">Todos</option>
                <option value="active"   {{ filter_status == 'active'   ? 'selected' : '' }}>Activo</option>
                <option value="inactive" {{ filter_status == 'inactive' ? 'selected' : '' }}>Inactivo</option>
            </select>
        </div>

        {# Acciones #}
        <div style="display:flex;gap:.5rem;flex-shrink:0;padding-bottom:1px">
            <button type="submit" class="btn" style="width:auto;padding:.45rem 1rem;font-size:.875rem">Filtrar</button>
            {% if search or filter_role or filter_status %}
                <a href="/admin/users" class="btn-outline"
                   style="padding:.4rem .875rem;text-decoration:none;font-size:.875rem;display:inline-flex;align-items:center">
                    Limpiar
                </a>
            {% endif %}
        </div>

    </form>
</div>

{# ── Tabla ───────────────────────────────────────────────────────────────── #}
{% if users is empty %}
<div class="card">
    <div class="u-empty" role="status">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m9-4.13a4 4 0 11-8 0 4 4 0 018 0zm6 4a4 4 0 00-4-4"/>
        </svg>
        <p class="font-semibold" style="color:var(--fg)">Sin usuarios</p>
        <p class="text-sm">No hay usuarios que coincidan con los filtros aplicados.</p>
    </div>
</div>
{% else %}
<div class="card" style="padding:0;overflow:hidden">
    <div style="overflow-x:auto">
        <table class="user-table" aria-label="Lista de usuarios">
            <thead>
                <tr>
                    <th scope="col">Usuario</th>
                    <th scope="col">Correo</th>
                    <th scope="col">Rol</th>
                    <th scope="col">Estado</th>
                    <th scope="col">Creado</th>
                    <th scope="col" style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody id="users-tbody">
                {% for user in users %}
                <tr id="row-{{ user.id }}" data-id="{{ user.id }}">
                    <td>
                        <div class="flex items-center gap-2">
                            {# Avatar con inicial #}
                            <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0"
                                 style="background:var(--primary,#00BFFF);line-height:1"
                                 aria-hidden="true">
                                {{ user.name|slice(0,1)|upper }}
                            </div>
                            <span class="font-medium" style="color:var(--fg)">{{ user.name }}</span>
                        </div>
                    </td>
                    <td style="color:var(--muted)">{{ user.email }}</td>
                    <td>
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold"
                              style="background:#e0f2fe;color:#0369a1">
                            {{ user.role.label ?? '—' }}
                        </span>
                    </td>
                    <td>
                        {% if user.active %}
                            <span class="badge-status badge-active" aria-label="Activo">Activo</span>
                        {% else %}
                            <span class="badge-status badge-inactive" aria-label="Inactivo">Inactivo</span>
                        {% endif %}
                    </td>
                    <td style="color:var(--muted);font-size:.8125rem">
                        {{ user.created_at ? user.created_at|date('d/m/Y') : '—' }}
                    </td>
                    <td>
                        <div class="flex items-center justify-end gap-1">
                            {# Editar #}
                            <button type="button"
                                    class="btn-icon btn-icon-edit"
                                    aria-label="Editar usuario {{ user.name }}"
                                    data-action="edit"
                                    data-id="{{ user.id }}"
                                    data-name="{{ user.name|e('html_attr') }}"
                                    data-email="{{ user.email|e('html_attr') }}"
                                    data-role="{{ user.role_id }}">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 012.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-1.414A2 2 0 019.586 13z"/>
                                </svg>
                            </button>

                            {# Activar / Desactivar #}
                            <button type="button"
                                    class="btn-icon btn-icon-toggle {{ user.active ? '' : 'is-inactive' }}"
                                    aria-label="{{ user.active ? 'Desactivar' : 'Activar' }} usuario {{ user.name }}"
                                    data-action="toggle"
                                    data-id="{{ user.id }}">
                                {% if user.active %}
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M5 13l4 4L19 7"/>
                                </svg>
                                {% else %}
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                                {% endif %}
                            </button>

                            {# Eliminar #}
                            <button type="button"
                                    class="btn-icon btn-icon-delete"
                                    aria-label="Eliminar usuario {{ user.name }}"
                                    data-action="delete"
                                    data-id="{{ user.id }}"
                                    data-name="{{ user.name|e('html_attr') }}">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7V4h6v3M4 7h16"/>
                                </svg>
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Paginación ──────────────────────────────────────────────────────────── #}
{% if total_pages > 1 %}
<div class="flex items-center justify-between mt-4 flex-wrap gap-2">
    <span style="color:var(--muted);font-size:.875rem">
        Página {{ page }} de {{ total_pages }} ({{ total }} usuarios)
    </span>
    <div class="flex gap-2">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ search }}&role_id={{ filter_role }}&status={{ filter_status }}"
           class="btn-outline" style="padding:.5rem .875rem;text-decoration:none">← Anterior</a>
        {% endif %}
        {% if page < total_pages %}
        <a href="?page={{ page + 1 }}&q={{ search }}&role_id={{ filter_role }}&status={{ filter_status }}"
           class="btn-outline" style="padding:.5rem .875rem;text-decoration:none">Siguiente →</a>
        {% endif %}
    </div>
</div>
{% else %}
<p style="text-align:right;color:var(--muted);font-size:.8125rem;margin-top:.75rem">
    {{ total }} usuario{{ total != 1 ? 's' : '' }}
</p>
{% endif %}
{% endif %}

{# ── Modal Crear / Editar ───────────────────────────────────────────────── #}
<div id="user-modal" class="u-modal-backdrop" role="dialog" aria-modal="true"
     aria-labelledby="modal-title" hidden>
    <div class="u-modal-box" role="document">
        <div class="flex items-start justify-between mb-5">
            <h2 id="modal-title" class="text-lg font-semibold" style="color:var(--fg)">
                Nuevo usuario
            </h2>
            <button type="button" id="modal-close" class="btn-icon"
                    style="background:#f1f5f9;color:var(--muted)"
                    aria-label="Cerrar modal">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form id="user-form" novalidate>
            <input type="hidden" id="f-id" name="id" value="">

            <div class="u-field">
                <label for="f-name">Nombre completo <span aria-hidden="true" style="color:#ef4444">*</span></label>
                <input id="f-name" name="name" type="text" class="u-input"
                       autocomplete="name" maxlength="150" required
                       aria-describedby="err-name" aria-required="true">
                <span id="err-name" class="u-field-error" role="alert"></span>
            </div>

            <div class="u-field">
                <label for="f-email">Correo electrónico <span aria-hidden="true" style="color:#ef4444">*</span></label>
                <input id="f-email" name="email" type="email" class="u-input"
                       autocomplete="email" maxlength="254" required
                       aria-describedby="err-email" aria-required="true">
                <span id="err-email" class="u-field-error" role="alert"></span>
            </div>

            <div class="u-field">
                <label for="fm-role">Rol <span aria-hidden="true" style="color:#ef4444">*</span></label>
                <select id="fm-role" name="role_id" class="u-input" required
                        aria-describedby="err-role" aria-required="true">
                    <option value="">Selecciona un rol…</option>
                    {% for role in roles %}
                    <option value="{{ role.id }}">{{ role.label }}</option>
                    {% endfor %}
                </select>
                <span id="err-role" class="u-field-error" role="alert"></span>
            </div>

            <div class="u-field" id="pw-wrap">
                <label for="f-password">
                    Contraseña <span id="pw-optional-hint" style="color:var(--muted);font-weight:400;font-size:.75rem"></span>
                    <span id="pw-required-mark" aria-hidden="true" style="color:#ef4444">*</span>
                </label>
                <input id="f-password" name="password" type="password" class="u-input"
                       autocomplete="new-password" maxlength="128"
                       aria-describedby="err-password pw-strength-label">
                <div class="pw-strength-bar" aria-hidden="true">
                    <div id="pw-strength-fill" class="pw-strength-fill"></div>
                </div>
                <span id="pw-strength-label" class="pw-label" aria-live="polite"></span>
                <span id="err-password" class="u-field-error" role="alert"></span>
            </div>

            <div class="flex justify-end gap-2 mt-6">
                <button type="button" id="modal-cancel" class="btn-outline"
                        style="padding:.6rem 1.1rem">
                    Cancelar
                </button>
                <button type="submit" id="modal-submit" class="btn"
                        style="width:auto;padding:.6rem 1.5rem">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>

{# ── Área de toasts ─────────────────────────────────────────────────────── #}
<div id="toast-area" class="u-toast-wrap" aria-live="polite" aria-atomic="true"></div>

{% endblock %}

{% block scripts %}
<script>
(function () {
'use strict';

/* ── CSRF token ─────────────────────────────────────────────────────── */
const CSRF = document.querySelector('meta[name="csrf-token"]')?.content ?? '';

/* ── Toast ──────────────────────────────────────────────────────────── */
function toast(msg, type = 'success') {
    const area = document.getElementById('toast-area');
    const el = document.createElement('div');
    el.className = `u-toast ${type}`;
    el.setAttribute('role', 'status');
    el.innerHTML = `
        <svg style="width:1.1rem;height:1.1rem;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            ${type === 'success'
                ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>'
                : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>'}
        </svg>
        <span>${escHtml(msg)}</span>`;
    area.appendChild(el);
    setTimeout(() => el.remove(), 3800);
}

function escHtml(s) {
    return String(s).replace(/[&<>"']/g, c =>
        ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
}

/* ── Modal ──────────────────────────────────────────────────────────── */
const modal        = document.getElementById('user-modal');
const modalTitle   = document.getElementById('modal-title');
const form         = document.getElementById('user-form');
const fId          = document.getElementById('f-id');
const fName        = document.getElementById('f-name');
const fEmail       = document.getElementById('f-email');
const fRole        = document.getElementById('fm-role');
const fPassword    = document.getElementById('f-password');
const submitBtn    = document.getElementById('modal-submit');
const pwOptHint    = document.getElementById('pw-optional-hint');
const pwReqMark    = document.getElementById('pw-required-mark');
const pwFill       = document.getElementById('pw-strength-fill');
const pwLabel      = document.getElementById('pw-strength-label');

let isEditing = false;

function openModal(editing = false, data = {}) {
    isEditing = editing;
    modalTitle.textContent = editing ? 'Editar usuario' : 'Nuevo usuario';
    fId.value       = data.id       ?? '';
    fName.value     = data.name     ?? '';
    fEmail.value    = data.email    ?? '';
    fPassword.value = '';
    pwFill.style.width      = '0';
    pwFill.style.background = '';
    pwLabel.textContent     = '';

    // Rol
    fRole.value = data.role ?? '';

    // Contraseña opcional en edición
    if (editing) {
        pwOptHint.textContent = '(opcional — déjala vacía para no cambiarla)';
        pwReqMark.hidden = true;
        fPassword.required = false;
    } else {
        pwOptHint.textContent = '';
        pwReqMark.hidden = false;
        fPassword.required = true;
    }

    clearErrors();
    modal.hidden = false;
    // Pequeño delay para la animación de entrada
    requestAnimationFrame(() => modal.classList.add('open'));
    fName.focus();
}

function closeModal() {
    modal.classList.remove('open');
    setTimeout(() => { modal.hidden = true; }, 250);
}

document.getElementById('btn-new-user').addEventListener('click', () => openModal(false));
document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('modal-cancel').addEventListener('click', closeModal);
modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.hidden) closeModal(); });

/* ── Strength meter ─────────────────────────────────────────────────── */
const STRENGTH = [
    { min: 0,  color: '#ef4444', label: 'Muy débil',   width: '20%' },
    { min: 1,  color: '#f97316', label: 'Débil',        width: '40%' },
    { min: 2,  color: '#eab308', label: 'Regular',      width: '65%' },
    { min: 3,  color: '#22c55e', label: 'Fuerte',       width: '85%' },
    { min: 4,  color: '#15803d', label: 'Muy fuerte',   width: '100%' },
];

function calcStrength(pw) {
    let score = 0;
    if (pw.length >= 8)  score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;
    return score;
}

fPassword.addEventListener('input', () => {
    const pw = fPassword.value;
    if (pw.length === 0) {
        pwFill.style.width = '0';
        pwLabel.textContent = '';
        return;
    }
    const level = STRENGTH[Math.min(calcStrength(pw), STRENGTH.length - 1)];
    pwFill.style.width      = level.width;
    pwFill.style.background = level.color;
    pwLabel.textContent     = level.label;
    pwLabel.style.color     = level.color;
});

/* ── Validación del formulario ──────────────────────────────────────── */
function showError(inputEl, errEl, msg) {
    inputEl.classList.add('invalid');
    inputEl.setAttribute('aria-invalid', 'true');
    errEl.textContent = msg;
    errEl.classList.add('show');
}

function clearError(inputEl, errEl) {
    inputEl.classList.remove('invalid');
    inputEl.removeAttribute('aria-invalid');
    errEl.textContent = '';
    errEl.classList.remove('show');
}

function clearErrors() {
    [
        [fName,     document.getElementById('err-name')],
        [fEmail,    document.getElementById('err-email')],
        [fRole,     document.getElementById('err-role')],
        [fPassword, document.getElementById('err-password')],
    ].forEach(([el, err]) => clearError(el, err));
}

function applyServerErrors(errors) {
    const map = {
        name:     [fName,     document.getElementById('err-name')],
        email:    [fEmail,    document.getElementById('err-email')],
        role_id:  [fRole,     document.getElementById('err-role')],
        password: [fPassword, document.getElementById('err-password')],
    };
    Object.entries(errors).forEach(([field, msg]) => {
        if (map[field]) showError(...map[field], msg);
    });
}

/* ── Submit ─────────────────────────────────────────────────────────── */
form.addEventListener('submit', async e => {
    e.preventDefault();
    clearErrors();

    // Validación cliente básica
    let valid = true;
    if (!fName.value.trim()) {
        showError(fName, document.getElementById('err-name'), 'El nombre es requerido.');
        valid = false;
    }
    if (!fEmail.value.trim()) {
        showError(fEmail, document.getElementById('err-email'), 'El correo es requerido.');
        valid = false;
    }
    if (!fRole.value) {
        showError(fRole, document.getElementById('err-role'), 'Selecciona un rol.');
        valid = false;
    }
    if (!isEditing && !fPassword.value) {
        showError(fPassword, document.getElementById('err-password'), 'La contraseña es requerida.');
        valid = false;
    }
    if (!valid) return;

    const body = new FormData();
    body.append('_token', CSRF);
    body.append('name',     fName.value.trim());
    body.append('email',    fEmail.value.trim());
    body.append('role_id',  fRole.value);
    body.append('password', fPassword.value);

    const url    = isEditing ? `/admin/users/${fId.value}` : '/admin/users';
    const method = isEditing ? 'POST' : 'POST';

    if (isEditing) body.append('_method', 'PUT');

    submitBtn.disabled = true;
    submitBtn.textContent = 'Guardando…';

    try {
        const res = await fetch(url, { method, body });
        const json = await res.json();

        if (!json.ok) {
            if (json.errors) applyServerErrors(json.errors);
            else toast(json.message ?? 'Error al guardar.', 'error');
            return;
        }

        closeModal();
        toast(isEditing ? 'Usuario actualizado correctamente.' : 'Usuario creado correctamente.');

        // Actualizar fila o recargar
        if (isEditing && json.user) {
            updateRow(json.user);
        } else {
            setTimeout(() => location.reload(), 600);
        }
    } catch {
        toast('Error de red. Intenta de nuevo.', 'error');
    } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Guardar';
    }
});

/* ── Delegación de eventos en tabla ─────────────────────────────────── */
document.getElementById('users-tbody')?.addEventListener('click', async e => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;

    const action = btn.dataset.action;
    const id     = btn.dataset.id;

    if (action === 'edit') {
        openModal(true, {
            id:    id,
            name:  btn.dataset.name,
            email: btn.dataset.email,
            role:  btn.dataset.role,
        });
        return;
    }

    if (action === 'toggle') {
        await doToggle(id, btn);
        return;
    }

    if (action === 'delete') {
        const name = btn.dataset.name;
        if (!confirm(`¿Eliminar al usuario "${name}"? Esta acción no se puede deshacer.`)) return;
        await doDelete(id);
    }
});

async function doToggle(id, btn) {
    btn.disabled = true;
    try {
        const body = new FormData();
        body.append('_token', CSRF);
        body.append('_method', 'PATCH');

        const res  = await fetch(`/admin/users/${id}/toggle`, { method: 'POST', body });
        const json = await res.json();

        if (!json.ok) { toast(json.message ?? 'No se pudo cambiar el estado.', 'error'); return; }

        const row    = document.getElementById(`row-${id}`);
        const badge  = row?.querySelector('.badge-status');
        const active = json.active;

        if (badge) {
            badge.textContent = active ? 'Activo' : 'Inactivo';
            badge.className   = `badge-status ${active ? 'badge-active' : 'badge-inactive'}`;
            badge.setAttribute('aria-label', active ? 'Activo' : 'Inactivo');
        }

        btn.classList.toggle('is-inactive', !active);
        btn.setAttribute('aria-label', `${active ? 'Desactivar' : 'Activar'} usuario`);
        btn.innerHTML = active
            ? `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`
            : `<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>`;

        toast(active ? 'Usuario activado.' : 'Usuario desactivado.');
    } catch { toast('Error de red.', 'error'); }
    finally  { btn.disabled = false; }
}

async function doDelete(id) {
    try {
        const body = new FormData();
        body.append('_token', CSRF);
        body.append('_method', 'DELETE');

        const res  = await fetch(`/admin/users/${id}`, { method: 'POST', body });
        const json = await res.json();

        if (!json.ok) { toast(json.message ?? 'No se pudo eliminar el usuario.', 'error'); return; }

        const row = document.getElementById(`row-${id}`);
        if (row) {
            row.style.transition = 'opacity .3s';
            row.style.opacity    = '0';
            setTimeout(() => row.remove(), 320);
        }
        toast('Usuario eliminado.');
    } catch { toast('Error de red.', 'error'); }
}

/* ── Actualizar fila existente en DOM ───────────────────────────────── */
function updateRow(u) {
    const row = document.getElementById(`row-${u.id}`);
    if (!row) return;

    // Avatar inicial
    const avatar = row.querySelector('[aria-hidden="true"].rounded-full');
    if (avatar) avatar.textContent = u.name.charAt(0).toUpperCase();

    const cells = row.querySelectorAll('td');
    // td[0] name span
    const nameSpan = cells[0].querySelector('.font-medium');
    if (nameSpan) nameSpan.textContent = u.name;

    // td[1] email
    cells[1].textContent = u.email;

    // td[2] role badge
    const roleBadge = cells[2].querySelector('span');
    if (roleBadge) roleBadge.textContent = u.role_label;

    // Actualizar data-* en edit button
    const editBtn = row.querySelector('[data-action="edit"]');
    if (editBtn) {
        editBtn.dataset.name  = u.name;
        editBtn.dataset.email = u.email;
        editBtn.dataset.role  = u.role_id;
    }
}

})();
</script>
{% endblock %}