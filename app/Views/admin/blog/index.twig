{% extends 'layouts/app.twig' %}

{% block title %}Blog — {{ app_name }}{% endblock %}
{% block page_title %}Gestión de Blog{% endblock %}

{% block breadcrumbs %}
<nav class="breadcrumbs" aria-label="Ruta de navegación">
    <ol>
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item breadcrumb-active">Blog</li>
    </ol>
</nav>
{% endblock %}

{% block head %}
<style>
.post-table { width:100%; border-collapse:collapse; }
.post-table th { background:var(--bg); color:var(--muted); font-size:.7rem; font-weight:700;
    text-transform:uppercase; letter-spacing:.05em; padding:.625rem 1rem; text-align:left;
    border-bottom:1px solid var(--border); }
.post-table td { padding:.75rem 1rem; border-bottom:1px solid var(--border); font-size:.875rem; vertical-align:middle; }
.post-table tbody tr:last-child td { border-bottom:none; }
.post-table tbody tr:hover { background:var(--bg); }
.post-table .post-title { font-weight:600; color:var(--navy); max-width:280px; }
.post-table .post-title small { display:block; font-size:.75rem; color:var(--muted); font-weight:400; margin-top:.15rem; }

/* Status badges */
.s-badge { display:inline-flex; align-items:center; gap:.3rem; padding:.2rem .65rem;
    border-radius:9999px; font-size:.72rem; font-weight:700; white-space:nowrap; }
.s-badge--published { background:#f0fdf4; color:#15803d; }
.s-badge--draft     { background:#f1f5f9; color:#64748b; }
.s-badge--scheduled { background:#fffbeb; color:#b45309; }

/* Acciones rápidas */
.btn-xs { display:inline-flex; align-items:center; gap:.25rem; padding:.3rem .65rem;
    border-radius:6px; font-size:.75rem; font-weight:600; border:none; cursor:pointer;
    text-decoration:none; transition:background .15s; }
.btn-xs-edit   { background:#dbeafe; color:#1d4ed8; }
.btn-xs-edit:hover { background:#bfdbfe; text-decoration:none; }
.btn-xs-pub    { background:#dcfce7; color:#15803d; }
.btn-xs-pub:hover { background:#bbf7d0; }
.btn-xs-unpub  { background:#fef3c7; color:#b45309; }
.btn-xs-unpub:hover { background:#fde68a; }
.btn-xs-del    { background:#fee2e2; color:#dc2626; }
.btn-xs-del:hover { background:#fecaca; }

.post-views { color:var(--muted); font-size:.8125rem; }
</style>
{% endblock %}

{% block content %}

{# ── Header ─────────────────────────────────────────────────────────────── #}
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;gap:1rem;flex-wrap:wrap">
    <p style="color:var(--muted);font-size:.875rem">{{ total }} artículo{{ total != 1 ? 's' : '' }}</p>
    <div style="display:flex;gap:.625rem">
        <a href="/blog" target="_blank" class="btn-outline"
           style="padding:.55rem 1rem;text-decoration:none;font-size:.875rem">
            Ver blog ↗
        </a>
        <a href="/admin/blog/create" class="btn" style="width:auto;padding:.6rem 1.25rem">
            ＋ Nuevo artículo
        </a>
    </div>
</div>

{# ── Filtros ─────────────────────────────────────────────────────────────── #}
<div class="card" style="padding:.75rem 1.25rem;margin-bottom:1.25rem">
    <form method="GET" action="/admin/blog"
          style="display:flex;align-items:flex-end;gap:.75rem;flex-wrap:wrap">

        <div style="flex:1;min-width:180px">
            <label style="display:block;font-size:.75rem;font-weight:600;color:var(--muted);margin-bottom:.3rem">Buscar</label>
            <input type="search" name="q" value="{{ search }}" placeholder="Título…"
                   style="width:100%;padding:.45rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.875rem;font-family:inherit;outline:none">
        </div>

        <div style="width:130px">
            <label style="display:block;font-size:.75rem;font-weight:600;color:var(--muted);margin-bottom:.3rem">Estado</label>
            <select name="status" style="width:100%;padding:.45rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.875rem;font-family:inherit">
                <option value="">Todos</option>
                <option value="published" {{ filter_status == 'published' ? 'selected' : '' }}>Publicado</option>
                <option value="draft"     {{ filter_status == 'draft'     ? 'selected' : '' }}>Borrador</option>
                <option value="scheduled" {{ filter_status == 'scheduled' ? 'selected' : '' }}>Programado</option>
            </select>
        </div>

        <div style="width:160px">
            <label style="display:block;font-size:.75rem;font-weight:600;color:var(--muted);margin-bottom:.3rem">Categoría</label>
            <select name="category_id" style="width:100%;padding:.45rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.875rem;font-family:inherit">
                <option value="">Todas</option>
                {% for cat in categories %}
                <option value="{{ cat.id }}" {{ filter_category == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div style="display:flex;gap:.5rem;padding-bottom:1px">
            <button type="submit" class="btn" style="width:auto;padding:.45rem 1rem;font-size:.875rem">Filtrar</button>
            {% if search or filter_status or filter_category %}
            <a href="/admin/blog" class="btn-outline" style="padding:.4rem .875rem;font-size:.875rem;text-decoration:none;display:inline-flex;align-items:center">Limpiar</a>
            {% endif %}
        </div>
    </form>
</div>

{# ── Tabla de posts ──────────────────────────────────────────────────────── #}
{% if posts is empty %}
<div class="card" style="text-align:center;padding:3rem 1rem;color:var(--muted)">
    No hay artículos. <a href="/admin/blog/create" style="color:var(--sky-dk)">Crear el primero</a>.
</div>
{% else %}
<div class="card" style="padding:0;overflow:hidden">
    <div style="overflow-x:auto">
        <table class="post-table" aria-label="Lista de artículos">
            <thead>
                <tr>
                    <th>Artículo</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th>Publicado</th>
                    <th style="text-align:center">Vistas</th>
                    <th style="text-align:right">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for post in posts %}
                <tr id="post-row-{{ post.id }}">
                    <td class="post-title">
                        {{ post.title }}
                        <small>/blog/{{ post.slug }}</small>
                    </td>
                    <td>
                        {% if post.category %}
                        <span style="font-size:.8rem;color:var(--muted)">{{ post.category.name }}</span>
                        {% else %}<span style="color:var(--border)">—</span>{% endif %}
                    </td>
                    <td>
                        {% if post.status == 'published' %}
                            <span class="s-badge s-badge--published">● Publicado</span>
                        {% elseif post.status == 'scheduled' %}
                            <span class="s-badge s-badge--scheduled">◷ Programado</span>
                        {% else %}
                            <span class="s-badge s-badge--draft">○ Borrador</span>
                        {% endif %}
                    </td>
                    <td style="font-size:.8125rem;color:var(--muted)">
                        {{ post.published_at ? post.published_at|date('d/m/Y H:i') : '—' }}
                    </td>
                    <td class="post-views" style="text-align:center">{{ post.views }}</td>
                    <td>
                        <div style="display:flex;align-items:center;justify-content:flex-end;gap:.375rem">
                            <a href="/admin/blog/{{ post.id }}/edit" class="btn-xs btn-xs-edit"
                               aria-label="Editar {{ post.title }}">
                                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 012.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-1.414A2 2 0 019.586 13z"/></svg>
                                Editar
                            </a>
                            <button type="button"
                                    class="btn-xs {{ post.status == 'published' ? 'btn-xs-unpub' : 'btn-xs-pub' }}"
                                    data-action="publish"
                                    data-id="{{ post.id }}"
                                    data-status="{{ post.status }}"
                                    aria-label="{{ post.status == 'published' ? 'Despublicar' : 'Publicar' }} {{ post.title }}">
                                {{ post.status == 'published' ? 'Despublicar' : 'Publicar' }}
                            </button>
                            <button type="button"
                                    class="btn-xs btn-xs-del"
                                    data-action="delete"
                                    data-id="{{ post.id }}"
                                    data-title="{{ post.title|e('html_attr') }}"
                                    aria-label="Eliminar {{ post.title }}">
                                Eliminar
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Paginación #}
{% if total_pages > 1 %}
<div style="display:flex;align-items:center;justify-content:space-between;margin-top:1rem;flex-wrap:wrap;gap:.5rem">
    <span style="color:var(--muted);font-size:.875rem">Página {{ page }} de {{ total_pages }}</span>
    <div style="display:flex;gap:.5rem">
        {% if page > 1 %}
        <a href="?page={{ page - 1 }}&q={{ search }}&status={{ filter_status }}&category_id={{ filter_category }}"
           class="btn-outline" style="padding:.5rem .875rem;text-decoration:none">← Anterior</a>
        {% endif %}
        {% if page < total_pages %}
        <a href="?page={{ page + 1 }}&q={{ search }}&status={{ filter_status }}&category_id={{ filter_category }}"
           class="btn-outline" style="padding:.5rem .875rem;text-decoration:none">Siguiente →</a>
        {% endif %}
    </div>
</div>
{% endif %}
{% endif %}

<div id="toast-area" class="u-toast-wrap" aria-live="polite"></div>

{% endblock %}

{% block scripts %}
<script>
const CSRF = document.querySelector('meta[name="csrf-token"]')?.content ?? '';

function toast(msg, type = 'success') {
    const area = document.getElementById('toast-area');
    if (!area) return;
    const el = document.createElement('div');
    el.className = `u-toast ${type}`;
    el.textContent = msg;
    area.appendChild(el);
    setTimeout(() => el.remove(), 3500);
}

document.addEventListener('click', async e => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;

    const action = btn.dataset.action;
    const id     = btn.dataset.id;

    if (action === 'publish') {
        btn.disabled = true;
        try {
            const fd = new FormData();
            fd.append('_token', CSRF);
            const res  = await fetch(`/admin/blog/${id}/publish`, { method: 'POST', body: fd });
            const json = await res.json();
            if (json.ok) {
                const row    = document.getElementById(`post-row-${id}`);
                const badge  = row?.querySelector('.s-badge');
                const isNowPublished = json.status === 'published';

                if (badge) {
                    badge.className = `s-badge s-badge--${json.status}`;
                    badge.textContent = isNowPublished ? '● Publicado' : '○ Borrador';
                }

                btn.className    = `btn-xs ${isNowPublished ? 'btn-xs-unpub' : 'btn-xs-pub'}`;
                btn.textContent  = isNowPublished ? 'Despublicar' : 'Publicar';
                btn.dataset.status = json.status;

                toast(isNowPublished ? 'Artículo publicado.' : 'Artículo movido a borrador.');
            }
        } catch { toast('Error de red.', 'error'); }
        finally { btn.disabled = false; }
    }

    if (action === 'delete') {
        const title = btn.dataset.title;
        if (!confirm(`¿Eliminar "${title}"? No se puede deshacer.`)) return;

        btn.disabled = true;
        try {
            const fd = new FormData();
            fd.append('_token', CSRF);
            fd.append('_method', 'DELETE');
            const res  = await fetch(`/admin/blog/${id}`, { method: 'POST', body: fd });
            const json = await res.json();
            if (json.ok) {
                const row = document.getElementById(`post-row-${id}`);
                row && (row.style.transition = 'opacity .3s', row.style.opacity = '0',
                        setTimeout(() => row.remove(), 320));
                toast('Artículo eliminado.');
            }
        } catch { toast('Error de red.', 'error'); }
        finally { btn.disabled = false; }
    }
});
</script>
{% endblock %}