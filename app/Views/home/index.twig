{% extends 'layouts/app.twig' %}
{% import 'components/stat_card.twig' as stat %}
{% import 'components/badge.twig' as badge %}

{% block title %}Inicio — {{ app_name }}{% endblock %}
{% block page_title %}Inicio{% endblock %}

{% block breadcrumbs %}
<nav class="breadcrumbs" aria-label="Ruta de navegación">
    <ol>
        <li class="breadcrumb-item breadcrumb-active">Inicio</li>
    </ol>
</nav>
{% endblock %}

{% block content %}

    <div class="stats-grid">
        {{ stat.render('Usuario', auth_user_name)|raw }}
        {{ stat.render('Rol', auth_role|capitalize, 'navy')|raw }}
    </div>

    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Bienvenido a {{ app_name }}</h2>
            {{ badge.render('v1.0', 'primary')|raw }}
        </div>
        <p style="color:var(--muted); font-size:.9rem; line-height:1.7">
            Este es el núcleo del framework. Extiende esta vista o reemplázala
            con el dashboard de tu proyecto.
        </p>
    </div>

{% endblock %}