# ── Aplicación ────────────────────────────────────────────────────────────────
APP_ENV=dev            # dev | prod | stop
APP_URL=               # https://miapp.com  (vacío = autodetect)
APP_TIMEZONE=America/Mexico_City
EMPRESA_NOMBRE=MiSistema

# ── Base de datos ──────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=szm_core
DB_USERNAME=root
DB_PASSWORD=mysql

# ── Sesión ─────────────────────────────────────────────────────────────────────
SESSION_NAME=SZM_SESSION
SESSION_LIFETIME=120   # minutos
SESSION_SECURE=false   # true en producción con HTTPS
SESSION_SAMESITE=Lax

# ── WAF ────────────────────────────────────────────────────────────────────────
# IPs exentas de inspección (ops/admin). Vacío = el WAF inspecciona TODAS las IPs.
# En dev dejar vacío para que el laboratorio de pruebas funcione correctamente.
# En prod: WAF_TRUSTED_IPS=203.0.113.10,203.0.113.11
WAF_TRUSTED_IPS=

# Token HMAC para bypass manual vía cookie (admin en campo). Genera uno con:
#   php -r "echo bin2hex(random_bytes(32));"
WAF_BYPASS_SECRET=

# ── Correo electrónico ─────────────────────────────────────────────────────────
# Por defecto se usa NullMailer (loguea en storage/logs/mail-*.log, no envía).
# Para envío real, configura estas variables e implementa SmtpMailer en providers.php.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=SZM

# ── Redis (opcional) ───────────────────────────────────────────────────────────
# Si está vacío, el WAF opera en modo MySQL puro (sin caché de baneos en memoria).
REDIS_HOST=
REDIS_PORT=6379

# ── Telegram (opcional) ────────────────────────────────────────────────────────
# Notificaciones de intrusión en tiempo real. Dejar vacío para desactivar.
TELEGRAM_BOT_TOKEN=8095427215:AAGVqDSBBuqGWuG-NwPoUCzHGLRWBda02wI
TELEGRAM_CHAT_ID=952711507