# =============================================================================
# SZM-Core — .gitignore
# =============================================================================

# ── Entorno ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Dependencias ──────────────────────────────────────────────────────────────
/vendor/

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── Caché de Twig ─────────────────────────────────────────────────────────────
/storage/cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
/storage/logs/

# ── Uploads ───────────────────────────────────────────────────────────────────
/storage/uploads/
!/storage/uploads/.gitkeep

# ── FileCache (driver de caché en disco) ──────────────────────────────────────
/storage/filecache/
!/storage/filecache/.gitkeep

# ── PHPUnit ───────────────────────────────────────────────────────────────────
/.phpunit.cache/
/.phpunit.result.cache
/coverage/

# ── HTMLPurifier cache ────────────────────────────────────────────────────────
/storage/htmlpurifier/*
!/storage/htmlpurifier/.gitkeep

# ── PHP CS Fixer ──────────────────────────────────────────────────────────────
/.php-cs-fixer.cache
/.php_cs.cache
/storage/cache/.php-cs-fixer.cache

# ── PHPStan ───────────────────────────────────────────────────────────────────
/.phpstan.cache/

# ── Node (por si se añade tooling frontend en el futuro) ──────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace
nbproject/

# ── Editores ──────────────────────────────────────────────────────────────────
*~
*.swp
*.swo
*.bak
*.tmp

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini