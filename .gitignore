# =============================================================================
# SZM-Core — .gitignore
# =============================================================================

# ── Entorno ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Dependencias ──────────────────────────────────────────────────────────────
/vendor/

# ── Caché de Twig ─────────────────────────────────────────────────────────────
/storage/cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
/storage/logs/

# ── Uploads ───────────────────────────────────────────────────────────────────
/storage/uploads/

# ── PHPUnit ───────────────────────────────────────────────────────────────────
/.phpunit.cache/
/.phpunit.result.cache
/coverage/

# ── PHP CS Fixer ──────────────────────────────────────────────────────────────
/.php-cs-fixer.cache
/.php_cs.cache

# ── PHPStan ───────────────────────────────────────────────────────────────────
/.phpstan.cache/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace
nbproject/

# ── Editores ──────────────────────────────────────────────────────────────────
*~
*.swp
*.swo
*.bak
*.tmp

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini